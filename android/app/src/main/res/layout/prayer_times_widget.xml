<?xml version="1.0" encoding="utf-8"?>
<!-- All attributes are inlined: RemoteViews does not reliably support the
     `style` attribute, which triggers "Problem loading widget". -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pt_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <!-- Header: date + city -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/pt_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#56BC7C"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/pt_city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8CFFFFFF"
            android:textSize="12sp"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Divider — a LinearLayout (allowed by RemoteViews); a bare <View> is not. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        android:background="#22FFFFFF" />

    <!-- Imsak -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">
        <TextView
            android:id="@+id/name_imsak"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#B3FFFFFF"
            android:textSize="15sp"
            android:maxLines="1" />
        <TextView
            android:id="@+id/time_imsak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Gunes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">
        <TextView
            android:id="@+id/name_gunes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#B3FFFFFF"
            android:textSize="15sp"
            android:maxLines="1" />
        <TextView
            android:id="@+id/time_gunes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Ogle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">
        <TextView
            android:id="@+id/name_ogle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#B3FFFFFF"
            android:textSize="15sp"
            android:maxLines="1" />
        <TextView
            android:id="@+id/time_ogle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Ikindi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">
        <TextView
            android:id="@+id/name_ikindi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#B3FFFFFF"
            android:textSize="15sp"
            android:maxLines="1" />
        <TextView
            android:id="@+id/time_ikindi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Aksam -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">
        <TextView
            android:id="@+id/name_aksam"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#B3FFFFFF"
            android:textSize="15sp"
            android:maxLines="1" />
        <TextView
            android:id="@+id/time_aksam"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Yatsi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">
        <TextView
            android:id="@+id/name_yatsi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#B3FFFFFF"
            android:textSize="15sp"
            android:maxLines="1" />
        <TextView
            android:id="@+id/time_yatsi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1" />
    </LinearLayout>

</LinearLayout>
